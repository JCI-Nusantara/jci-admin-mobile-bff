# Base image tag from CI (GHCR)
BFF_IMAGE=ghcr.io/<org-or-user>/jci-admin-mobile-bff:staging

# Directus
DIRECTUS_KEY=change-me
DIRECTUS_SECRET=change-me
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=change-me
DIRECTUS_DB_CONNECTION_STRING=postgresql://<user>:<pass>@<host>:5432/<db>
DIRECTUS_PUBLIC_URL=https://staging.cms.example.com

# Saleor
SALEOR_DB_CONNECTION_STRING=postgresql://<user>:<pass>@<host>:5432/<db>
SALEOR_SECRET_KEY=change-me
SALEOR_ALLOWED_HOSTS=staging.saleor.example.com,localhost,127.0.0.1
SALEOR_DEFAULT_FROM_EMAIL=no-reply@example.com

# BFF
AUTH0_DOMAIN=your-tenant.au.auth0.com
AUTH0_CLIENT_ID=change-me
AUTH0_AUDIENCE=https://api.example.com
AUTH0_ADMIN_ROLE=admin
DIRECTUS_URL=http://directus:8055
DIRECTUS_STATIC_TOKEN=change-me
DIRECTUS_MEMBERS_COLLECTION=profiles
SALEOR_API_URL=http://saleor-api:8000/graphql/
SALEOR_API_TOKEN=change-me
SALEOR_CHANNEL_ID=default-channel
MIDTRANS_SERVER_KEY=change-me
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_NOTIFICATION_URL=https://staging-api.example.com/webhooks/midtrans
PUBLIC_BASE_URL=https://staging-api.example.com
DIRECTUS_SYNC_WEBHOOK_SECRET=change-me
DIRECTUS_SYNC_LOG_ENABLED=true
DIRECTUS_SYNC_LOG_COLLECTION=vendure_sync_logs
